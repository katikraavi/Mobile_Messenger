# Local environment variables for docker-compose
# Fill in SMTP_FROM_EMAIL and SMTP_PASSWORD with your real SendGrid values.

# Database Configuration
DATABASE_URL=postgres://messenger_user:messenger_password@postgres:5432/messenger_db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=messenger_db
DATABASE_USER=messenger_user
DATABASE_PASSWORD=messenger_password

# Serverpod Configuration
SERVERPOD_ENV=development
SERVERPOD_PORT=8081

# Frontend Configuration
FRONTEND_BUILD_MODE=debug
FLUTTER_BUILD_NUMBER=1
FLUTTER_BUILD_NAME=1.0.0

# Application Configuration
APP_NAME=Mobile Messenger
APP_VERSION=1.0.0
APP_DEBUG=true

# SMTP Configuration
# This local ignored file is now configured for Gmail SMTP, so plain
# `docker compose up` will send real emails from this machine.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=katikraavi@gmail.com
SMTP_FROM_NAME=Mobile Messanger app i created
SMTP_USER=katikraavi@gmail.com
SMTP_PASSWORD=hjco skeh oqse veux
SMTP_SECURE=false

# APK Distribution
BACKEND_HOST=172.31.195.26
